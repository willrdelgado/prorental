# ─────────────────────────────────────────────────────────────
# ProRental — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# RealtyAPI.io — https://realtyapi.io
# Provides: Zillow property data, Zestimate, rent estimates,
#           sale/rental comps, market stats, tax history
# Free tier: 250 req/month | Pro: $20/mo for 20K requests
REALTYAPI_KEY=your_realtyapi_key_here

# Server port (optional, defaults to 3000)
PORT=3000
